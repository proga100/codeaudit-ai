{
  "name": "@codeaudit/db",
  "version": "0.1.0",
  "private": true,
  "description": "Drizzle ORM schema and database client for CodeAudit",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "drizzle-kit": "drizzle-kit",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "drizzle-orm": "^0.36.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.27.0",
    "typescript": "^5.7.0"
  }
}
