# =============================================================================
# CodeAudit Environment Variables
# Copy this file to .env.local (Next.js) and .env (worker)
# =============================================================================

# Database (Neon or local Docker Postgres)
# Local dev: postgres://codeaudit:codeaudit_dev_password@localhost:5432/codeaudit
# Neon: use the connection string from Neon dashboard (pooled mode for App Router)
DATABASE_URL=postgres://codeaudit:codeaudit_dev_password@localhost:5432/codeaudit

# Redis (local Docker or Upstash)
# Local dev:
REDIS_URL=redis://:redis_dev_password@localhost:6379

# Auth.js
# Generate: openssl rand -base64 32
AUTH_SECRET=REPLACE_WITH_RANDOM_SECRET_32_BYTES

# GitHub OAuth (for Auth.js)
# Create at: https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=REPLACE_WITH_GITHUB_CLIENT_ID
AUTH_GITHUB_SECRET=REPLACE_WITH_GITHUB_CLIENT_SECRET

# GitHub App (for repo access in worker)
# Create at: https://github.com/settings/apps/new
# Permissions: Contents: read
GITHUB_APP_ID=REPLACE_WITH_GITHUB_APP_ID
GITHUB_APP_PRIVATE_KEY=REPLACE_WITH_BASE64_ENCODED_PEM

# API Key Encryption Master Key
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This key encrypts user-provided LLM API keys using AES-256-GCM.
# Changing this key will invalidate all stored API keys.
API_KEY_ENCRYPTION_SECRET=REPLACE_WITH_64_HEX_CHARS_32_BYTES

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
