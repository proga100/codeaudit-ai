{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "composite": true
  },
  "references": [
    { "path": "./packages/db" },
    { "path": "./packages/audit-engine" },
    { "path": "./packages/llm-adapter" },
    { "path": "./packages/repo-sandbox" },
    { "path": "./worker" }
  ],
  "exclude": ["node_modules", "**/node_modules", "**/.next", "**/dist"]
}
